# Copy this file to ".env" and fill in the key(s) for the provider(s) you want to use.
# You only need a key for the provider you select in the dropdown.
#
# IMPORTANT: Vite inlines any VITE_-prefixed variable into the browser bundle.
# That is fine for local hackathon use (the key stays on your machine), but it
# means these keys WILL be exposed if you deploy this static site to a public URL.
# Do not commit your real ".env" — it is gitignored.

VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
