# Copy this file to ".env" and fill in the key(s) for the provider(s) you want to use.
# You only need a key for the provider you select in the dropdown.
#
# IMPORTANT: Vite inlines any VITE_-prefixed variable into the browser bundle.
# That is fine for local hackathon use (the key stays on your machine), but it
# means these keys WILL be exposed if you deploy this static site to a public URL.
# Do not commit your real ".env" — it is gitignored.

VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=

# Optional: ElevenLabs Speech-to-Text, used by the prompt-box mic button.
VITE_ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# DEPLOYED (Vercel) — server-side proxy mode. Do NOT use VITE_ keys above when
# deploying publicly; they would be exposed in the bundle. Instead:
#
#   1. Set this flag so the browser calls /api/* instead of the providers:
#        VITE_USE_PROXY=1
#   2. Set the SECRET keys WITHOUT the VITE_ prefix (server-only; never bundled).
#      Configure these in Vercel → Settings → Environment Variables, not here:
#        OPENAI_API_KEY=
#        ELEVENLABS_API_KEY=
#        ANTHROPIC_API_KEY=   # only if you offer Claude
#        GEMINI_API_KEY=      # only if you offer Gemini
#
# Leave VITE_USE_PROXY unset locally to keep the browser-direct path.
VITE_USE_PROXY=
